function updateWithdrawSource() {
    currentUser = allUsers.find(u => u.accountNumber === currentUser.accountNumber);
    const source = document.getElementById('withdrawSource').value;
    const label = document.getElementById('withdrawSourceLabel');
    const amountDisplay = document.getElementById('withdrawBalance');

    if(source === 'balance') {
        label.textContent = 'Available Balance';
        amountDisplay.textContent = currentUser.balance.toFixed(2);
    } else {
        label.textContent = 'Commission Balance';
        amountDisplay.textContent = currentUser.commission.toFixed(2);
    }
