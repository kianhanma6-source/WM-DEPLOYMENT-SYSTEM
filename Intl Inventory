}

function updateWithdrawDisplay() {
    currentUser = allUsers.find(u => u.accountNumber === currentUser.accountNumber);
    document.getElementById('wdName').value = currentUser.fullName;
    document.getElementById('wdWalletType').value = currentUser.ewallet;
    document.getElementById('wdWalletNo').value = currentUser.walletNo;
    document.getElementById('wdAmount').value = '';
    document.getElementById('feeDisplay').innerHTML = 'Processing Fee (2%): ₱0.00<br><strong>Total You Will Receive: ₱0.00</strong>';
    updateWithdrawSource();
}

function calcNetAmount() {
    const source = document.getElementById('withdrawSource').value;
    const amt = parseFloat(document.getElementById('wdAmount').value) || 0;
    let available = 0;

    if(source === 'balance') available = currentUser.balance;
    else available = currentUser.commission;

    if(amt <= 0) {
        document.getElementById('feeDisplay').innerHTML = 'Processing Fee (2%): ₱0.00<br><strong>Total You Will Receive: ₱0.00</strong>';
        return;
    }
    if(amt > available) {
        document.getElementById('feeDisplay').innerHTML = `<span style="color:#ffd700;">⚠️ Amount exceeds available ${source === 'balance' ? 'Balance' : 'Commission'}!</span><br>Processing Fee (2%): ₱0.00<br><strong>Total You Will Receive: ₱0.00</strong>`;
        return;
    }
    const fee = amt * PROCESSING_FEE;
    const net = amt - fee;
    document.getElementById('feeDisplay').innerHTML = `Processing Fee (2%): ₱${fee.toFixed(2)}<br><strong>Total You Will Receive: ₱${net.toFixed(2)}</strong>`;
}

