// ✅ DITO ANG PAGBABAGO: DADAGDAG LANG ANG TOTAL INVITES KAPAG NA-APPROVE NA ANG CASHIN
function approveCashin(idx) {
    const req = cashinRequests[idx];
    const user = allUsers.find(u => u.accountNumber === req.userId);
    if(user) {
        user.balance += req.amount;
        
        // KAPAG UNANG CASH-IN LANG IBIBIGAY ANG BONUS AT DADAGDAG ANG INVITE COUNT
        if(!user.hasCashin && user.referredBy) {
            const inviter = allUsers.find(u => u.accountNumber === user.referredBy);
            if(inviter) {
                inviter.commission += REFERRAL_BONUS;
                // AUTOMATIC DADAGDAG ANG TOTAL INVITES NG INVITER
                inviter.totalInvites = (inviter.totalInvites || 0) + 1;
                // I-UPDATE AGAD ANG DISPLAY KUNG ANG CURRENT USER AY ANG INVITER
                if(currentUser && currentUser.accountNumber === inviter.accountNumber) {
                    currentUser = inviter;
                    localStorage.setItem('INV_currentUser', JSON.stringify(currentUser));
                }
            }
        }
        user.hasCashin = true;
    }
    cashinRequests[idx].status = 'APPROVED';
    saveDB(); 
    loadAdminTransactions();
    alert('✅ Cash-in Approved! Bonus & Invite Count Updated!');
}

function rejectCashin(idx) { 
    cashinRequests[idx].status='REJECTED'; 
    saveDB(); 
    loadAdminTransactions();
    alert('❌ Cash-in Rejected!');
}

function approveWithdraw(idx) { 
    withdrawRequests[idx].status='COMPLETED'; 
    saveDB(); 
    loadAdminTransactions();
    alert('✅ Withdrawal Approved!');
}

function rejectWithdraw(idx) { 
    withdrawRequests[idx].status='REJECTED'; 
    saveDB(); 
    loadAdminTransactions();
    alert('❌ Withdrawal Rejected!');
}

