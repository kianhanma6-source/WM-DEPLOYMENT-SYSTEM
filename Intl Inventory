function selectPlan(el, days, interest) { 
    document.querySelectorAll('.plan-option').forEach(e => e.classList.remove('selected')); 
    el.classList.add('selected'); 
    selectedPlan = {days: days, percent: interest}; 
}

function startInvest() {
    const amt = parseFloat(document.getElementById('investAmt').value);
    if(!selectedPlan || isNaN(amt) || amt < 100 || amt > currentUser.balance) return alert('❌ Select plan or check amount/balance!');
    
    currentUser.balance -= amt;
    currentUser.totalInvestment = (currentUser.totalInvestment || 0) + amt;
    const startDate = new Date();
    const endDate = new Date();
    endDate.setDate(startDate.getDate() + selectedPlan.days);
    
    currentUser.investments.push({ 
        id: Date.now(),
        amount: amt,
        days: selectedPlan.days,
        percent: selectedPlan.percent,
        startDate: startDate.toLocaleString(),
        endDate: endDate.toLocaleString(),
        status: 'ACTIVE'
    });
    
    const userIndex = allUsers.findIndex(u => u.accountNumber === currentUser.accountNumber);
    if(userIndex !== -1) allUsers[userIndex] = currentUser;
    
    saveDB();
    updateUserDisplay();
    loadActiveInvest();
    alert('✅ Investment Started Successfully!');
    document.getElementById('investAmt').value = '';
    document.querySelectorAll('.plan-option').forEach(e => e.classList.remove('selected'));
    selectedPlan = null;
}

