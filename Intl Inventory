function submitCashin() {
    const amount = parseFloat(document.getElementById('cashinAmount').value);
    const refNo = document.getElementById('cashinRef').value.trim();
    
    if(isNaN(amount) || amount < 100 || !refNo) return alert('❌ Enter valid amount! Min ₱100.');
    if(!proofImageData) return alert('❌ Please upload proof of payment!');
    
    cashinRequests.push({
        id: Date.now(), 
        userId: currentUser.accountNumber, 
        name: currentUser.fullName,
        userWallet: `${currentUser.ewallet || 'Not Set'} - ${currentUser.walletNo || 'Not Set'}`,
        amount: amount, 
        refNo: refNo,
        proofImage: proofImageData,
        date: new Date().toLocaleString(), 
        status: 'ON PROCESS'
    });
    saveDB();
    alert('✅ Cash-in Request Sent! Waiting for approval.');
    document.getElementById('cashinAmount').value = '';
    document.getElementById('cashinRef').value = '';
    document.getElementById('proofFile').value = '';
    document.getElementById('proofPreviewContainer').classList.add('hidden');
    proofImageData = '';
}

function submitWithdraw() {
    const source = document.getElementById('withdrawSource').value;
    const name = document.getElementById('wdName').value.trim();
    const walletType = document.getElementById('wdWalletType').value;
    const walletNo = document.getElementById('wdWalletNo').value.trim();
    const amount = parseFloat(document.getElementById('wdAmount').value);
    
    if(!name || !walletNo || isNaN(amount)) return alert('❌ Fill all details!');
    if(amount < 100) return alert('❌ Minimum withdraw is ₱100!');

    if(source === 'balance' && amount > currentUser.balance) return alert('❌ Insufficient Available Balance!');
    if(source === 'commission' && amount > currentUser.commission) return alert('❌ Insufficient Commission Balance!');
    
    const fee = amount * PROCESSING_FEE;
    const receiveAmount = amount - fee;

    if(source === 'balance') currentUser.balance -= amount;
    else currentUser.commission -= amount;

    const userIndex = allUsers.findIndex(u => u.accountNumber === currentUser.accountNumber);
    if(userIndex !== -1) allUsers[userIndex] = currentUser;
    
    withdrawRequests.push({
        id: Date.now(),
        userId: currentUser.accountNumber,
        name: name,
        source: source === 'balance' ? 'Available Balance' : 'Commission',
        ewallet: walletType,
        walletNo: walletNo,
        amount: amount,
        fee: fee,
        receiveAmount: receiveAmount,
        date: new Date().toLocaleString(),
        status: 'ON PROCESS'
    });
    
    saveDB();
    updateUserDisplay();
    alert(`✅ Withdraw Request Sent!\nSource: ${source === 'balance' ? 'Available Balance' : 'Commission'}\nAmount: ₱${amount.toFixed(2)}\nFee: ₱${fee.toFixed(2)}\nYou Get: ₱${receiveAmount.toFixed(2)}`);
    
    if(!document.getElementById('userHistory').classList.contains('hidden')) {
        loadHistory();
    }
}

