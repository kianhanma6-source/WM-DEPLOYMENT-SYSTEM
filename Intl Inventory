<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>777PUB.co</title>
<style>
* { box-sizing: border-box; font-family: 'Segoe UI', sans-serif; margin: 0; padding: 0; }
body { background: #121721; min-height: 100vh; color: white; padding-bottom: 20px; }
.container { max-width: 430px; margin: 0 auto; background: #121721; min-height: 100vh; position: relative; }

.page-box { padding: 40px 20px 30px; min-height: 100vh; }
.login-title { font-size: 32px; font-weight: 900; color: #ffd700; text-align: center; margin-bottom: 25px; }
.input-field { width: 100%; padding: 16px 15px; border: 2px solid #334155; border-radius: 12px; background: #0f1419; color: white; font-size: 16px; margin-bottom: 12px; }
.input-field:disabled { background: #1e293b; color: #94a3b8; border-color: #334155; cursor: not-allowed; }
.select-field { width: 100%; padding: 16px 15px; border: 2px solid #334155; border-radius: 12px; background: #0f1419; color: white; font-size: 16px; margin-bottom: 12px; cursor: pointer; }
.input-label { font-size: 14px; font-weight: 600; margin-bottom: 5px; display: block; color: #cbd5e1; }
.btn-group { display: flex; gap: 10px; margin-top: 20px; }
.btn { flex: 1; padding: 15px; border-radius: 12px; font-size: 17px; font-weight: 700; border: none; cursor: pointer; }
.btn-login { background: #16a34a; color: white; }
.btn-exit { background: #ef4444; color: white; }
.btn-create { width: 100%; margin-top: 15px; background: #2563eb; color: white; padding: 14px; border-radius: 12px; font-size: 16px; font-weight: 600; }
.back-btn { position: absolute; top: 15px; left: 15px; background: #334155; color: white; border: none; padding: 8px 12px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; z-index: 99; }

.user-menu { position: sticky; top: 0; z-index: 999; display: flex; justify-content: space-around; padding: 10px 2px; background: #1e293b; border-radius: 0 0 12px 12px; margin-bottom: 20px; padding-top: 35px; }
.tab-item { text-align: center; font-size: 11px; color: #8892a8; cursor: pointer; padding: 4px 2px; font-weight: 600; flex: 1; }
.tab-item.active { color: white; font-weight: 700; border-bottom: 3px solid #ffd700; padding-bottom: 4px; }
.tab-icon { font-size: 20px; margin-bottom: 2px; display: block; }
.logout-btn { position: absolute; right: 15px; top: 5px; background: #ef4444; color: white; border: none; padding: 6px 10px; border-radius: 8px; font-size: 12px; font-weight: 600; cursor: pointer; z-index: 1000; }

.admin-menu { position: sticky; top: 0; z-index: 999; display: flex; justify-content: space-around; padding: 10px 2px; background: #1e293b; border-radius: 0 0 12px 12px; margin-bottom: 20px; padding-top: 35px; }
.admin-tab { text-align: center; font-size: 11px; color: #94a3b8; cursor: pointer; padding: 4px 2px; font-weight: 600; flex: 1; }
.admin-tab.active { color: #ffd700; font-weight: 700; border-bottom: 2px solid #ffd700; padding-bottom: 4px; }

.content { padding: 0 20px; }
.page-title { font-size: 28px; font-weight: 900; margin-bottom: 15px; color: #ffd700; text-align: center; }
.balance-box { background: linear-gradient(135deg, #1e40af, #3b82f6); padding: 15px; border-radius: 12px; margin-bottom: 20px; text-align: center; font-size: 22px; font-weight: 700; }
.fee-info { background: rgba(239,68,68,0.1); border: 1px solid #ef4444; padding: 10px; border-radius: 8px; margin-bottom: 15px; font-size: 14px; color: #fca5a5; }
.user-info-card { background: white; border-radius: 12px; padding: 20px; margin-bottom: 18px; border-left: 4px solid #2563eb; color: #1e3a8a; }
.user-name { font-size: 32px; font-weight: 900; text-align: center; margin-bottom: 15px; text-transform: uppercase; border-bottom: 1px solid #d1d5db; padding-bottom: 10px; }
.info-row { display: flex; align-items: center; gap: 10px; margin: 12px 0; font-size: 18px; font-weight: 600; }
.referral-box { background: #fef3c7; border-radius: 12px; padding: 18px; margin-bottom: 15px; color: #92400e; word-break: break-all; }
.copy-btn { width: 100%; margin-top: 10px; padding: 12px; border-radius: 8px; border: none; background: #2563eb; color: white; font-size: 16px; font-weight: 600; cursor: pointer; }
.invite-list { background: #1a1f2e; border-radius: 10px; padding: 12px; margin-bottom: 10px; font-size: 15px; }
.plan-option { width: 100%; padding: 14px; border: 2px solid #475569; border-radius: 12px; background: transparent; color: white; font-size: 18px; font-weight: 500; margin-bottom: 10px; text-align: left; cursor: pointer; }
.plan-option.selected { border-color: #22c55e; background: rgba(34,197,94,0.1); }
.action-btn { width: 100%; background: #16a34a; color: white; border: none; padding: 16px; border-radius: 12px; font-size: 20px; font-weight: 700; cursor: pointer; margin: 15px 0; }
.history-title { font-size: 18px; font-weight: 700; margin: 20px 0 10px; color: #fbbf24; }
.history-item { background: #1a1f2e; border-radius: 10px; padding: 12px; margin-bottom: 10px; font-size: 14px; line-height: 1.5; }
.admin-card { background: #1a1f2e; border-radius: 10px; padding: 12px; margin-bottom: 10px; font-size: 14px; line-height: 1.6; }
.status { padding: 3px 8px; border-radius: 6px; font-size: 12px; font-weight: 600; display: inline-block; margin: 5px 5px 5px 0; }
.status.pending { background: #fef3c7; color: #92400e; }
.status.onprocess { background: #dbeafe; color: #1e40af; }
.status.approved { background: #dcfce7; color: #166534; }
.status.completed { background: #dcfce7; color: #166534; }
.action-btns { margin-top: 8px; display: flex; gap: 8px; }
.btn-sm { padding: 6px 10px; border-radius: 6px; font-size: 12px; font-weight: 600; border: none; cursor: pointer; }
.btn-approve { background: #16a34a; color: white; }
.btn-reject { background: #ef4444; color: white; }
.empty { text-align: center; color: #64748b; padding: 30px; font-size: 16px; }
.hidden { display: none !important; }
.fixed-gcash { background: #0f1419; padding: 12px; border-radius: 8px; border: 1px solid #ffd700; margin-bottom: 15px; }
.file-input { background: #0f1419; padding: 12px; border-radius: 8px; border: 2px solid #334155; color: white; margin-bottom: 12px; width: 100%; }
.db-btn { right: 90px; background: #7c3aed; }

.preview-box { width: 100%; max-height: 200px; object-fit: contain; border-radius: 8px; margin: 10px 0; border: 2px dashed #ffd700; padding: 5px; background: #0f1419; cursor: pointer; }
.preview-img { width: 100%; height: auto; border-radius: 4px; }
.modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); z-index: 9999; align-items: center; justify-content: center; }
.modal.show { display: flex; }
.modal-img { max-width: 90%; max-height: 80vh; border-radius: 8px; }
.close-modal { position: absolute; top: 20px; right: 20px; color: white; font-size: 30px; font-weight: bold; cursor: pointer; background: #ef4444; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
</style>
</head>
<body>
<div class="container">

<div id="loginPage" class="page-box">
    <div class="login-title">🔐 LOGIN</div>
    <div class="content">
        <label class="input-label">Username / Account No:</label>
        <input type="text" id="loginUser" class="input-field" placeholder="Enter username or account no">
        <label class="input-label">Password:</label>
        <input type="password" id="loginPass" class="input-field" placeholder="Enter password">
        <div class="btn-group">
            <button class="btn btn-login" onclick="checkLogin()">✅ LOGIN</button>
            <button class="btn btn-exit" onclick="exitApp()">❌ EXIT</button>
        </div>
        <button class="btn btn-create" onclick="showRegister()">📝 CREATE NEW ACCOUNT</button>
    </div>
</div>

<div id="registerPage" class="page-box hidden">
    <button class="back-btn" onclick="showLogin()">⬅ BACK</button>
    <div class="login-title">📝 REGISTER ACCOUNT</div>
    <div class="content">
        <label class="input-label">Full Name:</label>
        <input type="text" id="regName" class="input-field" placeholder="Your Full Name">
        <label class="input-label">Username:</label>
        <input type="text" id="regUsername" class="input-field" placeholder="Create username">
        <label class="input-label">Password:</label>
        <input type="password" id="regPass" class="input-field" placeholder="Min 6 characters">
        <label class="input-label">E-Wallet / Bank Name:</label>
        <select id="regWallet" class="select-field">
            <option value="">-- Select Option --</option>
            <option value="GCash">GCash</option>
            <option value="Maya">Maya</option>
            <option value="BDO">BDO Unibank</option>
            <option value="BPI">Bank of the Philippine Islands</option>
            <option value="Metrobank">Metrobank</option>
            <option value="UnionBank">UnionBank</option>
            <option value="Security Bank">Security Bank</option>
            <option value="Landbank">Landbank of the PH</option>
            <option value="Other">Other / Not Listed</option>
        </select>
        <label class="input-label">Account / Mobile No.:</label>
        <input type="text" id="regAccNo" class="input-field" placeholder="Your number or account no">
        <label class="input-label">Referral Code (Optional):</label>
        <input type="text" id="refCode" class="input-field" placeholder="Enter inviter account no">
        <div class="btn-group">
            <button class="btn btn-login" onclick="registerUser()">✅ REGISTER</button>
            <button class="btn btn-exit" onclick="showLogin()">❌ CANCEL</button>
        </div>
    </div>
</div>

<div id="userMain" class="hidden">
    <button class="logout-btn" onclick="logout()">🚪 LOGOUT</button>
    <div class="user-menu">
        <div class="tab-item" onclick="showUserTab('home')"><span class="tab-icon">🏠</span>HOME</div>
        <div class="tab-item" onclick="showUserTab('cashin')"><span class="tab-icon">💳</span>CASH-IN</div>
        <div class="tab-item" onclick="showUserTab('refer')"><span class="tab-icon">🎁</span>REFER</div>
        <div class="tab-item" onclick="showUserTab('invest')"><span class="tab-icon">📈</span>INVEST</div>
        <div class="tab-item" onclick="showUserTab('withdraw')"><span class="tab-icon">💸</span>WITHDRAW</div>
        <div class="tab-item" onclick="showUserTab('history')"><span class="tab-icon">📜</span>HISTORY</div>
    </div>

    <div id="userHome" class="page-content content hidden">
        <div class="user-info-card">
            <div class="user-name" id="userFullName">USER NAME</div>
            <div class="info-row"><span>🏦</span>Account No.: <strong id="userAccount"></strong></div>
            <div class="info-row"><span>💵</span>Available Balance: ₱<span id="userBalance">0.00</span></div>
            <div class="info-row"><span>💰</span>Total Investment: ₱<span id="totalInvestAmt">0.00</span></div>
            <div class="info-row"><span>🎁</span>Total Commission: ₱<span id="userCommission">0.00</span></div>
            <div class="info-row"><span>👥</span>Total Invites: <strong id="totalInvites">0</strong></div>
            <div style="margin-top:15px; padding-top:12px; border-top:1px solid #ddd;">
                <div class="info-row" style="font-size:16px;"><span>🔗</span>Referral Code: <strong id="refCodeDisplay"></strong></div>
                <button class="copy-btn" onclick="copyCode()">📋 COPY CODE</button>
            </div>
        </div>
        <div class="referral-box">
            <strong>📤 YOUR REFERRAL LINK:</strong><br>
            <span id="refLink">https://777pub.co/register?ref=</span>
            <button class="copy-btn" onclick="copyRef()">📋 COPY LINK</button>
        </div>
    </div>

    <div id="userCashin" class="page-content content hidden">
        <div class="page-title">💳 CASH-IN REQUEST</div>
        <div class="fixed-gcash">
            <strong>📌 PAY TO THIS GCASH:</strong><br>
            Number: <strong>0562153676</strong><br>
            Name: <strong>GCash Official</strong>
        </div>
        <label class="input-label">👤 Your Full Name:</label>
        <input type="text" id="cashinNameId" class="input-field" disabled>
        <label class="input-label">🏦 Your E-Wallet / Bank:</label>
        <input type="text" id="cashinMethod" class="input-field" disabled>
        <label class="input-label">💵 Amount:</label>
        <input type="number" id="cashinAmount" class="input-field" placeholder="Enter amount (Min ₱100)">
        <label class="input-label">🔢 Reference Number:</label>
        <input type="text" id="cashinRef" class="input-field" placeholder="Enter transaction reference number">
        
        <label class="input-label">📸 Proof of Payment (Screenshot/Photo):</label>
        <input type="file" id="proofFile" class="file-input" accept="image/*" onchange="previewProof(this)">
        <div id="proofPreviewContainer" class="preview-box hidden" onclick="openModal(document.getElementById('proofPreview').src)">
            <img id="proofPreview" class="preview-img" src="" alt="Proof of Payment">
        </div>
        
        <button class="action-btn" onclick="submitCashin()">📤 CASH-IN</button>
    </div>

    <div id="userRefer" class="page-content content hidden">
        <div class="page-title">🎁 MY INVITES & COMMISSION</div>
        <div class="balance-box">Total Commission: ₱<span id="commBalance">0.00</span></div>
        <div class="history-title">👥 PEOPLE YOU INVITED</div>
        <div id="inviteList"><div class="empty">No invites yet.</div></div>
    </div>

    <div id="userInvest" class="page-content content hidden">
        <div class="page-title">📈 INVESTMENT PLANS</div>
        <div class="balance-box">Available Balance: ₱<span id="investBalance">0.00</span></div>
        <div class="history-title">🔴 ACTIVE INVESTMENTS</div>
        <div id="activeInvest"><div class="empty">No active investment.</div></div>
        <input type="number" id="investAmt" class="input-field" placeholder="Enter amount (Min ₱100)">
        <div class="plan-option" onclick="selectPlan(this,1,3)">✅  1 Day → 3% Interest</div>
        <div class="plan-option" onclick="selectPlan(this,18,5)">✅ 18 Days → 5% Interest</div>
        <div class="plan-option" onclick="selectPlan(this,30,8)">✅ 30 Days → 8% Interest</div>
        <button class="action-btn" onclick="startInvest()">🚀 START INVESTMENT</button>
    </div>

    <div id="userWithdraw" class="page-content content">
        <div class="page-title">💸 WITHDRAW FUNDS</div>
        <div class="balance-box">
            <span id="withdrawSourceLabel">Available Balance</span>: ₱<span id="withdrawBalance">0.00</span>
        </div>
        <div class="fee-info">ℹ️ Processing Fee: 2% per transaction | Minimum Withdraw: ₱100</div>
        <label class="input-label">📌 WITHDRAW FROM:</label>
        <select id="withdrawSource" class="select-field" onchange="updateWithdrawSource()">
            <option value="balance">💵 Available Balance</option>
            <option value="commission">🎁 Commission Balance</option>
        </select>
        <label class="input-label">👤 Full Name:</label>
        <input type="text" id="wdName" class="input-field" placeholder="Your Full Name">
        <label class="input-label">🏦 E-Wallet / Bank:</label>
        <select id="wdWalletType" class="select-field">
            <option value="GCash">GCash</option>
            <option value="Maya">Maya</option>
            <option value="BDO">BDO Unibank</option>
            <option value="BPI">Bank of the Philippine Islands</option>
            <option value="Metrobank">Metrobank</option>
            <option value="UnionBank">UnionBank</option>
            <option value="Other">Other</option>
        </select>
        <label class="input-label">🔢 Account / Mobile No.:</label>
        <input type="text" id="wdWalletNo" class="input-field" placeholder="Enter account number">
        <label class="input-label">💵 Amount to Withdraw:</label>
        <input type="number" id="wdAmount" class="input-field" placeholder="Enter amount" oninput="calcNetAmount()">
        <div class="fee-info" id="feeDisplay">
            Processing Fee (2%): ₱0.00<br>
            <strong>Total You Will Receive: ₱0.00</strong>
        </div>
        <button class="action-btn" onclick="submitWithdraw()">📤 SUBMIT WITHDRAWAL</button>
    </div>

    <div id="userHistory" class="page-content content hidden">
        <div class="page-title">📜 ALL TRANSACTIONS</div>
        <div class="history-title">💳 CASH-IN HISTORY</div>
        <div id="cashinHist"><div class="empty">No cash-in records.</div></div>
        <div class="history-title">💸 WITHDRAWAL HISTORY</div>
        <div id="withdrawHist"><div class="empty">No withdrawal records.</div></div>
        <div class="history-title">📈 INVESTMENT HISTORY</div>
        <div id="investHist"><div class="empty">No investment records.</div></div>
    </div>
</div>

<div id="adminPanel" class="hidden">
    <button class="logout-btn db-btn" onclick="showFullDatabase()">🗄️ VIEW DB</button>
    <button class="logout-btn" onclick="logout()">🚪 LOGOUT</button>
    <div class="admin-menu">
        <div class="admin-tab active" onclick="showAdminTab('ahome')"><span class="tab-icon">🏠</span>HOME</div>
        <div class="admin-tab" onclick="showAdminTab('arefer')"><span class="tab-icon">🎁</span>REFERRALS</div>
        <div class="admin-tab" onclick="showAdminTab('ainvest')"><span class="tab-icon">📈</span>INVESTMENTS</div>
        <div class="admin-tab" onclick="showAdminTab('atrans')"><span class="tab-icon">💳</span>TRANSACTIONS</div>
    </div>
    <div id="adminHome" class="content">
        <div class="page-title">👤 ALL REGISTERED USERS</div>
        <div id="adminUserList"></div>
    </div>
    <div id="adminRefer" class="content hidden"><div class="page-title">🎁 ALL REFERRALS</div><div id="adminReferList"></div></div>
    <div id="adminInvestPage" class="content hidden"><div class="page-title">📈 ALL INVESTMENTS</div><div id="adminInvestPageList"></div></div>
    <div id="adminTrans" class="content hidden">
        <div class="page-title">💳 CASH-IN REQUESTS</div><div id="adminCashinList"></div>
        <div class="page-title" style="margin-top:20px;">💸 WITHDRAWAL REQUESTS</div><div id="adminWithdrawList"></div>
    </div>
</div>
</div>

<div id="imageModal" class="modal" onclick="closeModal()">
    <span class="close-modal">&times;</span>
    <img id="modalImage" class="modal-img" src="" alt="Full View">
</div>

<script>
const ADMIN_USER = 'Blazark';
const ADMIN_PASS = 'Onin23';
const REFERRAL_BONUS = 50;
const GCASH_NUMBER = '0562153676';
const PROCESSING_FEE = 0.02;

let allUsers = JSON.parse(localStorage.getItem('INV_db_users') || '[]');
let cashinRequests = JSON.parse(localStorage.getItem('INV_db_cashin') || '[]');
let withdrawRequests = JSON.parse(localStorage.getItem('INV_db_withdraw') || '[]');
let currentUser = null;
let selectedPlan = null;
let runningTimer = null;
let proofImageData = '';

function saveDB() {
    localStorage.setItem('INV_db_users', JSON.stringify(allUsers));
    localStorage.setItem('INV_db_cashin', JSON.stringify(cashinRequests));
    localStorage.setItem('INV_db_withdraw', JSON.stringify(withdrawRequests));
}

function checkMaturedInvestments() {
    const now = new Date();
    allUsers.forEach(user => {
        if(!user.investments) return;
        user.investments.forEach(inv => {
            if(inv.status === 'ACTIVE') {
                const endDate = new Date(inv.endDate);
                if(now >= endDate) {
                    const profit = inv.amount * (inv.percent / 100);
                    user.balance += inv.amount + profit;
                    inv.status = 'COMPLETED';
                }
            }
        });
    });
    saveDB();
}

function checkSavedSession() {
    checkMaturedInvestments();
    const savedUser = localStorage.getItem('INV_currentUser');
    const isAdmin = localStorage.getItem('INV_isAdmin') === 'true';
    
    if(isAdmin) {
        document.getElementById('loginPage').classList.add('hidden');
        document.getElementById('adminPanel').classList.remove('hidden');
        loadAdminData();
        return;
    }
    
    if(savedUser) {
        currentUser = JSON.parse(savedUser);
        document.getElementById('loginPage').classList.add('hidden');
        document.getElementById('userMain').classList.remove('hidden');
        updateUserDisplay();
        document.getElementById('cashinNameId').value = currentUser.fullName;
        document.getElementById('cashinMethod').value = `${currentUser.ewallet || 'Not Set'} - ${currentUser.walletNo || 'Not Set'}`;
    }
}

function showRegister() { document.getElementById('loginPage').classList.add('hidden'); document.getElementById('registerPage').classList.remove('hidden'); }
function showLogin() { document.getElementById('registerPage').classList.add('hidden'); document.getElementById('loginPage').classList.remove('hidden'); }

function checkLogin() {
    const user = document.getElementById('loginUser').value.trim();
    const pass = document.getElementById('loginPass').value;
    
    if(user === ADMIN_USER && pass === ADMIN_PASS) {
        localStorage.setItem('INV_isAdmin', 'true');
        document.getElementById('loginPage').classList.add('hidden');
        document.getElementById('adminPanel').classList.remove('hidden');
        loadAdminData();
        return;
    }
    
    const found = allUsers.find(u => (u.username.toLowerCase() === user.toLowerCase() || u.accountNumber === user) && u.password === pass);
    if(!found) return alert('❌ Invalid username or password!');
    
    currentUser = found;
    localStorage.setItem('INV_isAdmin', 'false');
    localStorage.setItem('INV_currentUser', JSON.stringify(currentUser));
    document.getElementById('loginPage').classList.add('hidden');
    document.getElementById('userMain').classList.remove('hidden');
    updateUserDisplay();
    document.getElementById('cashinNameId').value = currentUser.fullName;
    document.getElementById('cashinMethod').value = `${currentUser.ewallet || 'Not Set'} - ${currentUser.walletNo || 'Not Set'}`;
}

function registerUser() {
    const name = document.getElementById('regName').value.trim();
    const user = document.getElementById('regUsername').value.trim();
    const pass = document.getElementById('regPass').value;
    const wallet = document.getElementById('regWallet').value;
    const walletNo = document.getElementById('regAccNo').value.trim();
    const refCode = document.getElementById('refCode').value.trim();
    
    if(!name || !user || pass.length < 6 || !wallet || !walletNo) return alert('❌ Fill all required fields! Password min 6 characters.');
    if(allUsers.find(x => x.username.toLowerCase() === user.toLowerCase())) return alert('❌ Username already taken!');
    
    let inviter = null;
    if(refCode) {
        inviter = allUsers.find(u => u.accountNumber === refCode);
        if(!inviter) return alert('❌ Referral code not found!');
    }
    
    const newUser = { 
        id: Date.now(), fullName: name, username: user, password: pass, 
        ewallet: wallet, walletNo: walletNo,
        accountNumber: 'INV-' + Math.random().toString(36).substring(2, 10).toUpperCase(), 
        balance: 0, commission: 0, totalInvestment: 0, 
        hasCashin: false, inviteList: [], referredBy: inviter ? inviter.accountNumber : null, 
        investments: [] 
    };
    
    allUsers.push(newUser);
    if(inviter) {
        inviter.inviteList.push(`${newUser.fullName} - ${newUser.accountNumber}`);
        // ❌ WALANG DAGDAG SA TOTAL INVITES DITO - GAGAWIN LANG KAPAG NAG-CASHIN NA
    }
    saveDB(); 
    alert('✅ Account Created Successfully!');
    showLogin();
}

function exitApp() { if(confirm('Exit application?')) window.close(); }
function logout() { 
    localStorage.removeItem('INV_currentUser'); 
    localStorage.removeItem('INV_lastPage'); 
    localStorage.removeItem('INV_isAdmin');
    if(runningTimer) clearInterval(runningTimer);
    document.getElementById('userMain').classList.add('hidden');
